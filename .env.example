# 三大法人監測系統 - 環境變數設定
# 複製此檔案為 .env，並填入你的設定值

# ==================== Telegram 通知設定 ====================
# Telegram Bot Token（從 @BotFather 取得）
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram Chat ID（你的個人 Chat ID 或群組 ID）
TELEGRAM_CHAT_ID=123456789

# ==================== Email 設定（已棄用，改用 Telegram） ====================
# 如果你還是想用 Email，可以取消註解以下設定
# EMAIL_TO=manyl1215@gmail.com
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=your-email@gmail.com

# ==================== 監測設定 ====================
# 監測股票清單（逗號分隔，留空則監測所有）
# 範例: 2330,2317,2454,2882,2412
WATCH_LIST=

# ==================== 警示門檻 ====================
# 大盤大額買賣門檻（億元）
THRESHOLD_MARKET_LARGE=50

# 個股大額買賣門檻（億元）
THRESHOLD_STOCK_LARGE=0.5

# 連續買賣天數門檻
THRESHOLD_CONSECUTIVE_DAYS=3

# ==================== GitHub Actions Secrets ====================
# 如果使用 GitHub Actions，請在 Repository Settings > Secrets 中設定：
# - TELEGRAM_BOT_TOKEN
# - TELEGRAM_CHAT_ID
# - WATCH_LIST (可選)

